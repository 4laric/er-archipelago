#!/usr/bin/env python3
r"""patch_apworld_base_hub_startgraces.py

Pre-light the always-open HUB grace(s) at load for base-game (non-dlc_only) region_lock seeds.

BUG
---
fill_slot_data builds `start_graces` ONLY inside `if self.options.dlc_only and world_logic < 3:`
(__init__.py ~L4605). So a base-game (dlc_only=false) region_lock seed emits NO real start graces:
- Limgrave and Roundtable Hold are NOT in REGION_GRACE_POINTS, so the on-receipt regionGraces path
  never lights them (no lock is *received* for an always-open region).
- early_leveling / warp can stop Melina's vanilla Roundtable hand-off from ever firing.
=> the player spawns at Limgrave with NO grace lit and no Roundtable -> can't reach the Twin Maiden
   shop / locks. (Observed: Limgrave start, no Roundtable, no graces ever.)

FIX
---
For non-dlc_only region_lock / region_lock_bosses seeds, add to start_graces:
- 71190  Roundtable Hold (the always-open hub) -- ALWAYS.
- 76101  The First Step (Limgrave opening grace) -- ONLY when Limgrave is the free start hub
         (NOT random_start). Under random_start Limgrave is a LOCKED region, so granting its grace
         would let you warp into Limgrave for free; light the ROLLED start region's graces instead
         (its precollected lock arrives name-unresolved, so on-receipt won't fire for it either).

Inserted right after the dlc_only start_graces block, before the Torrent/leveling additions, so all
the later `sorted(set(start_graces + [...]))` merges still apply.

Run on Windows from repo root (or the eldenring apworld dir):
    python patch_apworld_base_hub_startgraces.py
CRLF-safe byte splice; idempotent.
"""
import os, sys

HERE = os.path.dirname(os.path.abspath(__file__))
CANDS = [HERE, os.path.join(HERE, "Archipelago", "worlds", "eldenring")]
PKG = next((d for d in CANDS if os.path.exists(os.path.join(d, "__init__.py"))
            and os.path.exists(os.path.join(d, "grace_data.py"))), None)
if not PKG:
    sys.exit("ERROR: eldenring apworld dir not found (run from repo root or the apworld dir).")
P = os.path.join(PKG, "__init__.py")

with open(P, "rb") as f:
    b = f.read()
nl = b"\r\n" if b"\r\n" in b else b"\n"
def conv(s): return s.replace("\n", nl.decode("ascii")).encode("utf-8")

MARKER = "Base-game lock seeds: the always-open HUB"
if MARKER.encode("utf-8") in b:
    print("  [skip] base-hub start graces already present.")
    sys.exit(0)

ANCHOR = conv("            start_graces = sorted(set(int(_f) for _f in start_graces))\n")
if b.count(ANCHOR) != 1:
    sys.exit("  [FAIL] dlc_only start_graces anchor found %d times (expected 1); not modified." % b.count(ANCHOR))

INSERT = conv(
    "\n"
    "        # Base-game lock seeds: the always-open HUB graces are never lit by the on-receipt\n"
    "        # regionGraces path (no lock is *received* for an always-open region), and skip-Melina /\n"
    "        # warp can stop Melina's vanilla Roundtable hand-off from ever firing -- so the player can\n"
    "        # spawn at Limgrave with NO grace lit and no Roundtable. Pre-light the hub at load for\n"
    "        # non-dlc_only region_lock / region_lock_bosses seeds. (patch_apworld_base_hub_startgraces.py)\n"
    "        if not self.options.dlc_only and self.options.world_logic.value in (0, 2):\n"
    "            start_graces = sorted(set(start_graces + [71190]))  # Roundtable Hold (always-open hub)\n"
    "            if getattr(self, \"_random_start_region\", None):\n"
    "                # random_start: Limgrave is a LOCKED region now -- do NOT grant The First Step\n"
    "                # (76101) or you'd warp into Limgrave for free. Light the ROLLED start region's\n"
    "                # graces instead (its precollected lock arrives name-unresolved -> on-receipt skips).\n"
    "                start_graces = sorted(set(start_graces + [\n"
    "                    int(_p[0]) for _p in REGION_GRACE_POINTS.get(self._random_start_region, [])]))\n"
    "            else:\n"
    "                # Limgrave is the free start hub -> light The First Step (76101) as a warp anchor.\n"
    "                start_graces = sorted(set(start_graces + [76101]))\n"
)
b = b.replace(ANCHOR, ANCHOR + INSERT, 1)
with open(P, "wb") as f:
    f.write(b)
print("  [ok]   base-hub start graces added (Roundtable always; First Step only when Limgrave is the free start).")
print("DONE")
