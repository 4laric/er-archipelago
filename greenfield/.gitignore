# Greenfield scratch (most also caught by the repo-root .gitignore; repeated here so the
# greenfield tree is self-documenting and safe if committed as its own subtree).

# patch backups (.bak_phase0 / .bak_driftfix / ...) and one-off scratch
*.bak_*
_DELETE_ME*

# python caches
__pycache__/
*.pyc

# local Linux CI env, if GF_CI_HOME is pointed inside the repo
.greenfield-ci/

# AP gen output / logs if written under greenfield
out/
generate_greenfield_*.log

# NOTE: data.py and region_open_flags.py are GENERATED but COMMITTED on purpose --
# the drift gate compares them against a fresh gen. Do NOT ignore them.
